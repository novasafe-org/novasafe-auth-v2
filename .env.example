# =============================================================================
# NovaSafe Auth (start.novasafe.io) — environment template
# =============================================================================
#
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Fill in any values you want to override.
#   3. Start the dev server: pnpm dev
#
# RULES
#   - Never commit `.env` (real secrets). Only commit `.env.example`.
#   - Variables prefixed with VITE_ are exposed to the browser bundle.
#   - All other variables are server-only (TanStack Start SSR / Node runtime).
#   - Boolean envs accept: true | false | 1 | 0 | yes | no | on | off
#
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Modes: development | test | staging | production
NODE_ENV=development

# Port the SSR server listens on (and the Vite dev server in dev).
PORT=3001


# -----------------------------------------------------------------------------
# Public URLs (browser + server)
# -----------------------------------------------------------------------------
# Where THIS auth project is served (used to build absolute redirect URLs).
VITE_AUTH_URL=http://localhost:3001

# Marketing/landing site that links into this auth project.
VITE_LANDING_URL=http://localhost:3000

# Authenticated app users land in after sign-in.
VITE_APP_URL=http://localhost:3002

# NovaSafe Core Backend API base URL.
# Production: https://api.novasafe.io
# Local:      http://localhost:3125 (CORE_PORT in novasafe-backend)
VITE_API_URL=http://localhost:3125


# -----------------------------------------------------------------------------
# Auth cookie (server-only) — shared between auth + app subdomains
# -----------------------------------------------------------------------------
# Cookie name. Must match novasafe-app-v2.
AUTH_COOKIE_NAME=ns_session

# Domain attribute. Empty for localhost (host-only cookie).
# Production: .novasafe.io  (note the leading dot — required by some browsers).
AUTH_COOKIE_DOMAIN=

# Secure flag. false on localhost, true behind HTTPS.
AUTH_COOKIE_SECURE=false

# SameSite policy: lax | strict | none.
# Use "lax" for cross-subdomain redirects (start → app).
AUTH_COOKIE_SAMESITE=lax

# Cookie lifetime in seconds. Default: 7 days = 604800.
AUTH_COOKIE_MAX_AGE=1800


# -----------------------------------------------------------------------------
# OAuth providers (browser-bundled IDs)
# -----------------------------------------------------------------------------
# Google OAuth web client id (must match GOOGLE_WEB_CLIENT_ID on backend).
VITE_GOOGLE_WEB_CLIENT_ID=


# -----------------------------------------------------------------------------
# RevenueCat Web Billing (Paddle) — used by Pro signup paywall step
# -----------------------------------------------------------------------------
# Public web SDK key (safe for browser).
VITE_REVENUECAT_PUBLIC_API_KEY_WEB=

# Pro entitlement identifier (must match REVENUECAT_ENTITLEMENT_PRO on backend).
VITE_REVENUECAT_ENTITLEMENT_PRO=pro

# RevenueCat package identifiers — first match wins when looking up packages.
VITE_REVENUECAT_PACKAGE_MONTHLY=$rc_monthly
VITE_REVENUECAT_PACKAGE_YEARLY=$rc_annual


# -----------------------------------------------------------------------------
# Build / app metadata (stamped into outgoing API request headers)
# -----------------------------------------------------------------------------
VITE_APP_VERSION=0.1.0
